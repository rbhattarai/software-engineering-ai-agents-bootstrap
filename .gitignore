# Angular specific
/dist/
/out-tsc/
/tmp/
/coverage/
/e2e/test-output/
/.angular/
.angular/

# Node modules and dependency files
node_modules/
/package-lock.json
/yarn.lock

# Environment files
/.env

# Angular CLI and build artefacts
/.angular-cli.json
/.ng/

# TypeScript cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output & coverage anywhere (root rules above are anchored)
dist/
coverage/

# Playwright artifacts (app E2E tests)
test-results/
playwright-report/

# se-harness per-unit generated secrets (never committed; created by /harness-init)
.env.harness

# OS cruft
.DS_Store
Thumbs.db
