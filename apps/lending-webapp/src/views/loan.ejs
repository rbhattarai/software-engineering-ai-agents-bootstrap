<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/index">
                <i class="bi bi-building me-2"></i>Lending App
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/index">Dashboard</a>
                <a class="nav-link" href="/lendor">Lendors</a>
            </div>
        </div>
    </nav>

    <div class="container py-4" style="max-width: 720px;">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <h4 class="mb-0 text-muted">Loan Detail</h4>
        </div>

        <%
            const isClosed = loan.status === 'Approved' || loan.status === 'Rejected';
            const statusClass = loan.status === 'Approved'  ? 'bg-success' :
                                loan.status === 'Rejected'  ? 'bg-danger'  :
                                loan.status === 'Pending'   ? 'bg-warning text-dark' :
                                                              'bg-secondary';
        %>

        <!-- Loan Info Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">
                    <span class="badge bg-success bg-opacity-10 text-success fw-normal me-2" id="loanId"><%= loan.id %></span>
                </h6>
                <span class="badge <%= statusClass %>" id="loanStatus"><%= loan.status %></span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small">Applicant Name</div>
                        <div class="fw-semibold" id="applicantName"><%= loan.applicantName %></div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Amount</div>
                        <div class="fw-semibold" id="loanAmount">$<%= loan.amount.toLocaleString() %></div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Current Approver</div>
                        <div class="fw-semibold" id="currentApprover"><%= loan.approver || '—' %></div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Created At</div>
                        <div class="fw-semibold"><%= new Date(loan.createdAt).toLocaleString() %></div>
                    </div>
                </div>
            </div>
        </div>

        <% if (!isClosed) { %>

        <!-- Assign Approver -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-person-check me-2"></i>Assign Approver</h6>
            </div>
            <div class="card-body">
                <% if (approvers.length === 0) { %>
                    <p class="text-muted mb-0">
                        No approvers available. <a href="/lendor">Add an approver</a> first.
                    </p>
                <% } else { %>
                    <form method="POST" action="/loan/<%= loan.id %>" class="d-flex gap-2 align-items-end">
                        <input type="hidden" name="action" value="assign-approver">
                        <div class="flex-grow-1">
                            <label for="approver" class="form-label fw-semibold small">Select Approver</label>
                            <select class="form-select" id="approver" name="approver" required>
                                <option value="" disabled <% if (!loan.approver) { %>selected<% } %>>— choose approver —</option>
                                <% approvers.forEach(a => { %>
                                    <option value="<%= a.name %>" <% if (loan.approver === a.name) { %>selected<% } %>>
                                        <%= a.name %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success" id="assignApproverBtn">
                            <i class="bi bi-person-check me-1"></i> Assign
                        </button>
                    </form>
                <% } %>
            </div>
        </div>

        <!-- Approve / Reject -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-check2-circle me-2"></i>Decision</h6>
            </div>
            <div class="card-body">
                <% if (!loan.approver) { %>
                    <p class="text-muted mb-0">Assign an approver before making a decision.</p>
                <% } else { %>
                    <p class="text-muted small mb-3">
                        Approver <strong><%= loan.approver %></strong> is reviewing this loan.
                    </p>
                    <div class="d-flex gap-2">
                        <form method="POST" action="/loan/<%= loan.id %>">
                            <input type="hidden" name="action" value="approve">
                            <button type="submit" class="btn btn-success" id="approveLoanBtn">
                                <i class="bi bi-check-lg me-1"></i> Approve
                            </button>
                        </form>
                        <form method="POST" action="/loan/<%= loan.id %>">
                            <input type="hidden" name="action" value="reject">
                            <button type="submit" class="btn btn-danger" id="rejectLoanBtn">
                                <i class="bi bi-x-lg me-1"></i> Reject
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>

        <% } else { %>

        <!-- Closed state -->
        <div class="alert <%= loan.status === 'Approved' ? 'alert-success' : 'alert-danger' %> d-flex align-items-center gap-2">
            <i class="bi <%= loan.status === 'Approved' ? 'bi-check-circle-fill' : 'bi-x-circle-fill' %> fs-5"></i>
            <span>
                This loan has been <strong><%= loan.status.toLowerCase() %></strong>
                <% if (loan.approver) { %> by <strong><%= loan.approver %></strong><% } %>.
            </span>
        </div>

        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const es = new EventSource('/events');
        es.addEventListener('loan-updated', () => window.location.reload());
        es.onerror = () => { es.close(); setTimeout(() => window.location.reload(), 3000); };
    </script>
</body>
</html>
