<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/index">
                <i class="bi bi-building me-2"></i>Lending App
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link active" href="/index">Dashboard</a>
                <a class="nav-link" href="/lendor">Lendors</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <h4 class="mb-4 text-muted">Dashboard</h4>

        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                            <i class="bi bi-file-earmark-text fs-4 text-success"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Loans</div>
                            <div class="fs-3 fw-bold" id="totalLoans"><%= totalLoans %></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                            <i class="bi bi-currency-dollar fs-4 text-primary"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Amount</div>
                            <div class="fs-3 fw-bold" id="totalAmount">$<%= totalAmount.toLocaleString() %></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h6 class="mb-0 fw-semibold">Recent Loans</h6>
                <a href="/lendor" class="btn btn-sm btn-outline-success">Manage Lendors</a>
            </div>
            <div class="card-body p-0">
                <% if (latestLoans.length === 0) { %>
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No loans available yet.
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="recentLoansGrid">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Loan ID</th>
                                    <th>Applicant Name</th>
                                    <th class="text-end pe-4">Amount ($)</th>
                                    <th>Status</th>
                                    <th>Approver</th>
                                    <th>Created At</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% latestLoans.forEach(loan => { %>
                                <%
                                    const statusClass = loan.status === 'Approved' ? 'bg-success' :
                                                        loan.status === 'Rejected' ? 'bg-danger'  :
                                                        loan.status === 'Pending'  ? 'bg-warning text-dark' :
                                                                                     'bg-secondary';
                                %>
                                <tr>
                                    <td class="ps-4"><span class="badge bg-success bg-opacity-10 text-success fw-normal"><%= loan.id %></span></td>
                                    <td><%= loan.applicantName %></td>
                                    <td class="text-end pe-4 fw-semibold">$<%= loan.amount.toLocaleString() %></td>
                                    <td><span class="badge <%= statusClass %>"><%= loan.status %></span></td>
                                    <td class="text-muted"><%= loan.approver || '—' %></td>
                                    <td class="text-muted small"><%= new Date(loan.createdAt).toLocaleString() %></td>
                                    <td><a href="/loan/<%= loan.id %>" class="btn btn-sm btn-outline-success">View</a></td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const es = new EventSource('/events');
        es.addEventListener('loan-updated', () => window.location.reload());
        es.onerror = () => { es.close(); setTimeout(() => window.location.reload(), 3000); };
    </script>
</body>
</html>
