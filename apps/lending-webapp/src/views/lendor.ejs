<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/index">
                <i class="bi bi-building me-2"></i>Lending App
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/index">Dashboard</a>
                <a class="nav-link active" href="/lendor">Lendors</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0 text-muted">Lendor Management</h4>
            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#newApproverModal">
                <i class="bi bi-person-plus me-1"></i> Add New Loan Approver
            </button>
        </div>

        <!-- Add Approver Modal -->
        <div class="modal fade" id="newApproverModal" tabindex="-1" aria-labelledby="newApproverModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="newApproverModalLabel">Add New Loan Approver</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="POST" action="/lendor">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="approverName" class="form-label fw-semibold">Loan Approver Name</label>
                                <input type="text" class="form-control" id="approverName" name="approverName"
                                    placeholder="Enter approver name" required />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i> Submit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Approvers Grid -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Loan Approvers</h6>
            </div>
            <div class="card-body p-0">
                <% if (approvers.length === 0) { %>
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-people fs-1 d-block mb-2"></i>
                        No approvers yet. Click <strong>Add New Loan Approver</strong> to add one.
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="approversGrid">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Approver ID</th>
                                    <th>Name</th>
                                    <th>Added At</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% approvers.forEach(approver => { %>
                                <tr>
                                    <td class="ps-4"><span class="badge bg-success bg-opacity-10 text-success fw-normal"><%= approver.id %></span></td>
                                    <td><%= approver.name %></td>
                                    <td class="text-muted small"><%= new Date(approver.createdAt).toLocaleString() %></td>
                                    <td>
                                        <form method="POST" action="/lendor/<%= approver.id %>/delete" onsubmit="return confirm('Delete approver <%= approver.name %>?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Delete approver">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
