<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/index">
                <i class="bi bi-bank me-2"></i>Loan App
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/index">Dashboard</a>
                <a class="nav-link active" href="/loan">Loans</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0 text-muted">Loan Management</h4>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newLoanModal">
                <i class="bi bi-plus-lg me-1"></i> New Loan
            </button>
        </div>

        <!-- New Loan Modal -->
        <div class="modal fade" id="newLoanModal" tabindex="-1" aria-labelledby="newLoanModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="newLoanModalLabel">New Loan Application</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="POST" action="/loan">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="applicantName" class="form-label fw-semibold">Applicant Name</label>
                                <input type="text" class="form-control" id="applicantName" name="applicantName"
                                    placeholder="Enter applicant name" required />
                            </div>
                            <div class="mb-3">
                                <label for="amount" class="form-label fw-semibold">Loan Amount ($)</label>
                                <input type="number" class="form-control" id="amount" name="amount"
                                    placeholder="Enter loan amount" min="1" required />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i> Submit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Loans Grid -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">All Loans</h6>
            </div>
            <div class="card-body p-0">
                <% if (loans.length === 0) { %>
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No loans found. Click <strong>New Loan</strong> to create one.
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="loansGrid">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Loan ID</th>
                                    <th>Applicant Name</th>
                                    <th class="text-end pe-4">Amount ($)</th>
                                    <th>Status</th>
                                    <th>Approver</th>
                                    <th>Created At</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% loans.forEach(loan => { %>
                                <%
                                    const statusClass = loan.status === 'Approved' ? 'bg-success' :
                                                        loan.status === 'Rejected' ? 'bg-danger'  :
                                                        loan.status === 'Pending'  ? 'bg-warning text-dark' :
                                                                                     'bg-secondary';
                                %>
                                <tr>
                                    <td class="ps-4"><span class="badge bg-primary bg-opacity-10 text-primary fw-normal"><%= loan.id %></span></td>
                                    <td><%= loan.applicantName %></td>
                                    <td class="text-end pe-4 fw-semibold">$<%= loan.amount.toLocaleString() %></td>
                                    <td><span class="badge <%= statusClass %>"><%= loan.status %></span></td>
                                    <td class="text-muted"><%= loan.approver || '—' %></td>
                                    <td class="text-muted small"><%= new Date(loan.createdAt).toLocaleString() %></td>
                                    <td>
                                        <form method="POST" action="/loan/<%= loan.id %>/delete" onsubmit="return confirm('Delete loan <%= loan.id %>?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Delete loan">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const es = new EventSource('/events');
        es.addEventListener('loan-updated', () => window.location.reload());
        es.onerror = () => { es.close(); setTimeout(() => window.location.reload(), 3000); };
    </script>
</body>
</html>
