# .env.harness — GITIGNORED (A5 #3). Copy to .env.harness and fill in.
# Everything secret lives here; everything shareable lives in .harness/profile.yaml.

# Atlassian MCP (Jira stories, Confluence PRDs, XRay/Zephyr test cases)
ATLASSIAN_BASE_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# GitHub MCP (PRs)
GITHUB_TOKEN=

# Cloud provider (only the one named in profile.yaml `cloud:`)
AWS_PROFILE=
AZURE_SUBSCRIPTION_ID=
GCP_PROJECT=
VERCEL_TOKEN=

# SharePoint MCP (tier-3 wiki ingestion)
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
